--========================================================
-- BOOST FPS (DELETE MAP SAUF SOL / PERSOS)
--========================================================
local SavedMapParts = {}

local function applyBoostFPS()
    if BoostFPS_Active then return end
    BoostFPS_Active = true
    BoostFPSBtn.Text = "BOOST FPS: ON"
    toggleButton(BoostFPSBtn, true)

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local isPlayerChar = false
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character and obj:IsDescendantOf(plr.Character) then
                    isPlayerChar = true
                    break
                end
            end
            if not isPlayerChar then
                if obj.Name ~= "Baseplate" then
                    table.insert(SavedMapParts, {
                        Part = obj,
                        Transparency = obj.Transparency,
                        CanCollide = obj.CanCollide,
                        Material = obj.Material
                    })
                    obj.Transparency = 1
                    obj.CanCollide = false
                    obj.Material = Enum.Material.Air
                end
            end
        end
    end
end

local function restoreMap()
    BoostFPS_Active = false
    BoostFPSBtn.Text = "BOOST FPS: OFF"
    toggleButton(BoostFPSBtn, false)

    for _, data in ipairs(SavedMapParts) do
        if data.Part and data.Part.Parent then
            data.Part.Transparency = data.Transparency
            data.Part.CanCollide = data.CanCollide
            data.Part.Material = data.Material
        end
    end
    SavedMapParts = {}
end

BoostFPSBtn.MouseButton1Click:Connect(function()
    if not BoostFPS_Active then
        applyBoostFPS()
    else
        restoreMap()
    end
end)

