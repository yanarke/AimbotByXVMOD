local function updateSliderFromFOV()
    local t = (FOVRadius - MinFOV) / (MaxFOV - MinFOV)
    t = math.clamp(t,0,1)
    local minY = 10
    local maxY = 200 - 10 - 20
    local y = minY + (maxY - minY) * (1 - t)
    SliderKnob.Position = UDim2.new(0.5,-10,0,y)
    FOVLabel.Text = "FOV: "..tostring(math.floor(FOVRadius))
end
