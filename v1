--========================================================
-- FOV CIRCLE (DRAWING API)
--========================================================
local FOVCircle = Drawing and Drawing.new("Circle") or nil
if FOVCircle then
    FOVCircle.Color = Color3.fromRGB(0, 170, 255)
    FOVCircle.Thickness = 1.5
    FOVCircle.Filled = false
    FOVCircle.Radius = FOVRadius
    FOVCircle.Visible = true
end

local function updateFOVCircle()
    if not FOVCircle then return end
    local mousePos = UIS:GetMouseLocation()
    FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    FOVCircle.Radius = FOVRadius
end

--========================================================
-- RAYCAST PARAMS (ANTI-WALL)
--========================================================
local RaycastParamsObj = RaycastParams.new()
RaycastParamsObj.FilterType = Enum.RaycastFilterType.Blacklist

local function getCharacter(player)
    if not player or player == LocalPlayer then return nil end
    local char = player.Character
    if char and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
        return char
    end
    return nil
end

local function isVisible(head)
    if not head then return false end
    local origin = Camera.CFrame.Position
    local direction = (head.Position - origin)
    RaycastParamsObj.FilterDescendantsInstances = {LocalPlayer.Character or nil}
    local result = Workspace:Raycast(origin, direction, RaycastParamsObj)
    if result and result.Instance and result.Instance:IsDescendantOf(head.Parent) then
        return true
    end
    return false
end

--========================================================
-- GET CLOSEST TARGET IN FOV
--========================================================
local function getClosestTargetInFOV()
    local mousePos = UIS:GetMouseLocation()
    local closestPlayer = nil
    local closestDist = FOVRadius

    for _, plr in ipairs(Players:GetPlayers()) do
        local char = getCharacter(plr)
        if char then
            local head = char:FindFirstChild("Head")
            if head and isVisible(head) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(mousePos.X, mousePos.Y)).Magnitude
                    if dist <= closestDist then
                        closestDist = dist
                        closestPlayer = plr
                    end
                end
            end
        end
    end

    return closestPlayer
end

--========================================================
-- AIMLOCK LOGIC (HEAD)
--========================================================
local function aimAt(target)
    if not target then return end
    local char = getCharacter(target)
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)
end

local function isAimedAtHead(target)
    local char = getCharacter(target)
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end

    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
    if not onScreen then return false end

    local mousePos = UIS:GetMouseLocation()
    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
    return dist < 8
end

local function fireWeapon()
    VIM:SendMouseButtonEvent(0,0,0,true,game,0)
    VIM:SendMouseButtonEvent(0,0,0,false,game,0)
end

local function triggerbot()
    if TriggerBotEnabled and CurrentTarget and isAimedAtHead(CurrentTarget) then
        fireWeapon()
    end
end

local function updateTarget()
    CurrentTarget = getClosestTargetInFOV()
end

