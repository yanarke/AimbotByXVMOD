        draggingSlider = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local relY = input.Position.Y - SliderFrame.AbsolutePosition.Y
        local minY = 10
        local maxY = 200 - 10 - 20
        relY = math.clamp(relY, minY, maxY)
        SliderKnob.Position = UDim2.new(0.5,-10,0,relY)

        local t = 1 - ((relY - minY) / (maxY - minY))
        FOVRadius = math.floor(MinFOV + (MaxFOV - MinFOV) * t)
        FOVLabel.Text = "FOV: "..tostring(FOVRadius)
    end
end)

